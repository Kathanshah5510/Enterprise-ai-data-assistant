# Copy this file to k8s/secret.yaml and fill in your base64-encoded values.
# k8s/secret.yaml is git-ignored — never commit real secrets.
#
# To encode:  echo -n 'your-value' | base64
# To decode:  echo 'encoded' | base64 -d

apiVersion: v1
kind: Secret
metadata:
  name: eaida-secrets
  namespace: eaida
type: Opaque
data:
  POSTGRES_PASSWORD: <base64-encoded-password>
  # postgresql+psycopg://eaida:<password>@postgres:5432/eaida
  DATABASE_URL: <base64-encoded-database-url>
  SECRET_KEY: <base64-encoded-jwt-secret-key>
  GEMINI_API_KEY: <base64-encoded-gemini-api-key>
